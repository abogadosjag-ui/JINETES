{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REEMPLAZAR-CON-URL-RAILWAY/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://REEMPLAZAR-CON-URL-RAILWAY/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
