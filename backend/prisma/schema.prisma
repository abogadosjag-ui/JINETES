generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// role: "STUDENT" | "ADMIN"
// experienceLevel: "BEGINNER" | "INTERMEDIATE" | "ADVANCED"
model User {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  password         String
  role             String         @default("STUDENT")
  phone            String?
  emergencyContact String?
  experienceLevel  String         @default("BEGINNER")
  avatarUrl        String?
  isActive         Boolean        @default(true)
  inactiveSince    DateTime?
  createdAt        DateTime       @default(now())
  payments         Payment[]
  classBookings    ClassBooking[]
  cabalgatas       Cabalgata[]
}

// status: "PENDING" | "APPROVED" | "REJECTED"
model Payment {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  concept    String
  amount     Float
  proofFile  String
  status     String   @default("PENDING")
  adminNotes String?
  createdAt  DateTime @default(now())
}

model ClassSlot {
  id          String         @id @default(cuid())
  title       String
  instructor  String
  dateTime    DateTime
  duration    Int
  maxStudents Int            @default(5)
  createdAt   DateTime       @default(now())
  bookings    ClassBooking[]
}

// status: "CONFIRMED" | "CANCELLED"
model ClassBooking {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  slot      ClassSlot @relation(fields: [slotId], references: [id])
  slotId    String
  status    String    @default("CONFIRMED")
  createdAt DateTime  @default(now())

  @@unique([userId, slotId])
}

// status: "PENDING" | "CONFIRMED" | "CANCELLED"
model Cabalgata {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  date       DateTime
  numPeople  Int
  notes      String?
  status     String   @default("PENDING")
  adminNotes String?
  createdAt  DateTime @default(now())
}
